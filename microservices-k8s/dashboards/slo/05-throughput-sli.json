  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "education",
    "sli",
    "throughput",
    "slo-folder"
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "label": "Datasource"
      },
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(up{kubernetes_namespace=\"ecommerce\", app=~\"product-service|order-service|cart-service|payment-service|notification-service|user-service\"}, app)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "label": "Service"
      },
      {
        "name": "slo_availability",
        "type": "constant",
        "label": "Availability SLO (%)",
        "query": "99.9"
      },
      {
        "name": "slo_latency_ms",
        "type": "constant",
        "label": "Latency SLO (ms)",
        "query": "500"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Throughput SLI (Traffic)",
  "uid": "slo-05-throughput-sli",
